# Kubernetes Secret template for `medicare-secrets`
# Use this format for the Jenkins "Secret file" credential: medicare-secrets-env
# (Fill in real values; do NOT commit the real file)

# Auth
JWT_SECRET=
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=admin@medicare.com
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_FULL_NAME=Admin

# MongoDB URIs (used by the deployments via secretKeyRef)
MONGO_URI_AUTH=
MONGO_URI_PATIENT=
MONGO_URI_DOCTOR=
MONGO_URI_APPOINTMENT=
MONGO_URI_TELEMEDICINE=
MONGO_URI_PAYMENT=
MONGO_URI_NOTIFICATION=
MONGO_URI_AI=

# Notification service internal auth (used by telemedicine -> notification)
NOTIFICATION_INTERNAL_TOKEN=

# Notification email delivery (SendGrid)
NOTIFICATION_EMAIL_PROVIDER=sendgrid
NOTIFICATION_EMAIL_FROM=
SENDGRID_API_KEY=

# AI symptom service
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Payment service
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Patient-service storage (used by patient-service deployment)
# local | s3
PATIENT_STORAGE_PROVIDER=local
PATIENT_STORAGE_LOCAL_DIR=/data/patient-reports

# Patient-service security hardening
# Only enable true if calling patient-service directly without the gateway.
PATIENT_SECURITY_ACCEPT_BEARER=false

# Telemedicine -> notification integration
TELEMEDICINE_NOTIFICATION_ENABLED=true
TELEMEDICINE_NOTIFICATION_BASE_URL=http://notification-service:3007
TELEMEDICINE_NOTIFICATION_INTERNAL_TOKEN=
TELEMEDICINE_NOTIFICATION_TIMEOUT_MS=5000

# Notification recipient profile lookup
NOTIFICATION_PROFILE_LOOKUP_PATIENT_SERVICE_BASE_URL=http://patient-service:3002
NOTIFICATION_PROFILE_LOOKUP_DOCTOR_SERVICE_BASE_URL=http://doctor-service:3003
NOTIFICATION_PROFILE_LOOKUP_ACTOR_USER_ID=notification-service
NOTIFICATION_PROFILE_LOOKUP_ACTOR_ROLE=ADMIN
NOTIFICATION_PROFILE_LOOKUP_TIMEOUT_MS=5000

# Optional S3/MinIO settings (only used when PATIENT_STORAGE_PROVIDER=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
