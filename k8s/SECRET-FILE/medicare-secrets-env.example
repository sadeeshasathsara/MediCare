# Kubernetes Secret template for `medicare-secrets`
# Use this format for the Jenkins "Secret file" credential: medicare-secrets-env
# (Fill in real values; do NOT commit the real file)

# Auth
JWT_SECRET=
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=admin@medicare.com
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_FULL_NAME=Admin

# MongoDB URIs (used by the deployments via secretKeyRef)
MONGO_URI_AUTH=
MONGO_URI_PATIENT=
MONGO_URI_DOCTOR=
MONGO_URI_APPOINTMENT=
MONGO_URI_TELEMEDICINE=
MONGO_URI_PAYMENT=
MONGO_URI_NOTIFICATION=
MONGO_URI_AI=

# Patient-service storage (used by patient-service deployment)
# local | s3
PATIENT_STORAGE_PROVIDER=local
PATIENT_STORAGE_LOCAL_DIR=/data/patient-reports

# Patient-service security hardening
# Only enable true if calling patient-service directly without the gateway.
PATIENT_SECURITY_ACCEPT_BEARER=false

# Optional S3/MinIO settings (only used when PATIENT_STORAGE_PROVIDER=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
