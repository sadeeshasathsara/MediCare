# Authentication
JWT_SECRET=
JWT_ACCESS_TTL_MS=900000
JWT_REFRESH_TTL_MS=604800000

# Comma-separated list of allowed frontend origins for auth-service CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: bootstrap initial ADMIN user (disabled by default)
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=admin@medicare.com
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_FULL_NAME=Admin

# MongoDB Connections
MONGO_URI_AUTH=
MONGO_URI_PATIENT=
MONGO_URI_DOCTOR=
MONGO_URI_APPOINTMENT=
MONGO_URI_TELEMEDICINE=
MONGO_URI_PAYMENT=
MONGO_URI_NOTIFICATION=
MONGO_URI_AI=
