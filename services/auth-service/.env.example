SPRING_DATA_MONGODB_URI=mongodb://localhost:27017/auth-service

# Must be long (HS256). Example only.
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars

# Access token TTL (ms)
JWT_ACCESS_TTL_MS=900000

# Refresh token TTL (ms)
JWT_REFRESH_TTL_MS=604800000

# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: bootstrap initial ADMIN user (disabled by default)
ADMIN_BOOTSTRAP_ENABLED=false
ADMIN_BOOTSTRAP_EMAIL=admin@medicare.com
ADMIN_BOOTSTRAP_PASSWORD=change_me
ADMIN_BOOTSTRAP_FULL_NAME=Admin
