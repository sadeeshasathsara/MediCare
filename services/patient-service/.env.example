# Convenience base URLs (informational; not consumed by Spring Boot).
PATIENT_SERVICE_DIRECT_BASE_URL=http://localhost:3002
PATIENT_SERVICE_GATEWAY_BASE_URL=http://localhost:8080/api/patients

# MongoDB
# In Docker Compose, SPRING_DATA_MONGODB_URI is wired from the common/root .env (MONGO_URI_PATIENT).
# If running standalone (./mvnw ...), set SPRING_DATA_MONGODB_URI in your shell/IDE.

# Storage provider for uploaded patient documents (reports) and profile photos.
# local (default) stores files on disk; ensure you mount a volume in Docker/K8s.
PATIENT_STORAGE_PROVIDER=local
PATIENT_STORAGE_LOCAL_DIR=/data/patient-reports

# Only enable if calling patient-service directly without the gateway.
# In production, the gateway validates JWT and injects X-User-* headers.
PATIENT_SECURITY_ACCEPT_BEARER=false

# Optional S3/MinIO settings when PATIENT_STORAGE_PROVIDER=s3
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
